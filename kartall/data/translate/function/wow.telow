}, {color: "green", translate:"충돌 물리 개선에 도움을 준 제작자\n다른 할 일이 많아 마크라이더를 할 수 없다"}, {color: "yellow", translate:"은퇴한 제작자"}, {color: "green", translate:"사정이 있어 최신 트랙의 고스트를\n기록할 수 없는 제작자"}, {color: "yellow", translate:"★★☆☆☆"}, {color: "yellow", translate:"✵✵✵✵"}, {italic: 1b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"Never Gonna Give Bazzi Up"}, {italic: 0b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"Master"}, {italic: 0b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"Headphone"}, {italic: 1b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"Bazzi Rolling"}, {italic: 0b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"OUTPUT"}, {italic: 0b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"MIC.INPUT"}, {italic: 0b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"MIC.INPUT"}, {italic: 0b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"HEADPHONE"}, {italic: 0b, underlined: 0b, bold: 0b, color: "#FFFFFF", obfuscated: 0b, font: "minecraft:uniform", strikethrough: 0b, translate:"Mic."}, {color: "red", translate:"BGM 끄기"}, {color: "green", translate:"포레스트"}, {color: "yellow", translate:"사막"}, {color: "blue", translate:"빌리지"}, {color: "blue", translate:"아이스"}, {color: "red", translate:"공동묘지"}, {color: "light_purple", translate:"광산"}, {color: "light_purple", translate:"노르테유"}, {color: "yellow", translate:"팩토리"}, {color: "blue", translate:"해적"}, {color: "dark_blue", translate:"문힐시티"}, {color: "gold", translate:"황금문명"}, {color: 